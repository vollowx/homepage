---
import Layout from '../../layouts/Layout.astro'
import { toViewTransitionName } from '../../utils/css.ts';

const allPosts = Object.values(import.meta.glob('./*.md', { eager: true }))
  .sort((a: any, b: any) => {
    return new Date(b.frontmatter.pubDate).getTime()
      - new Date(a.frontmatter.pubDate).getTime();
  });
const uniqueTags = [
  ...new Set(allPosts.map((post: any) => post.frontmatter.tags).flat()),
]
---

<Layout title="Vollow's Blog">
  <section>
    <h1>Blog</h1>
    <h2>Tags</h2>
    <ul>
      {
        uniqueTags.map((tag: string) => (
          <li><a href={'/tags/' + tag} style={'view-transition-name: tag-'
            + tag}>{tag}</a></li>
        ))
      }
    </ul>
    <h2>Posts</h2>
    <ul>
      {
        allPosts.map((post: any) => (
          <li>
            <a href={post.url} style={'view-transition-name: post-title-'
              + toViewTransitionName(post.frontmatter.title)}>
              {post.frontmatter.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
